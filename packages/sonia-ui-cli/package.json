{
  "name": "@sonia/cli",
  "description": "Sonia UI command line",
  "type": "module",
  "version": "0.1.0-next.1",
  "files": [
    "lib"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "sonia": "lib/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts"
    ]
  },
  "scripts": {
    "prebuild": "tsc -p tsconfig.json",
    "build": "tsup",
    "build:dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "dev": "tsx --tsconfig tsconfig.json bin/cli.ts"
  },
  "dependencies": {
    "@antfu/ni": "^25.0.0",
    "@babel/core": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/plugin-transform-typescript": "^7.28.0",
    "@stricli/core": "^1.1.1",
    "cli-table3": "^0.6.3",
    "cosmiconfig": "^9.0.0",
    "deepmerge": "^4.3.1",
    "diff": "^8.0.2",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.1",
    "https-proxy-agent": "^7.0.6",
    "kleur": "^4.1.5",
    "node-fetch": "^3.3.2",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "recast": "^0.23.11",
    "ts-morph": "^26.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "type-fest": "^4.37.0",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@tsconfig/node20": "^20.1.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.11",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  }
}
