{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "customConditions": ["sui"],
    "incremental": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo.json",
    "declaration": true,
    "emitDeclarationOnly": false,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "**/node_modules"
  ]
}
