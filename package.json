{
  "name": "@sonia/ui",
  "description": "Design system components for your team.",
  "private": true,
  "type": "module",
  "author": "Eelco Wiersma <eelco@appulse.nl>",
  "license": "MIT",
  "keywords": [
    "react",
    "ui",
    "chakra-ui",
    "design-system",
    "react-components",
    "accessible",
    "components",
    "library"
  ],
  "scripts": {
    "w": "pnpm --filter",
    "dev:web": "pnpm --filter website dev",
    "changeset:next": "pnpm changeset pre enter next",
    "changeset:version": "changeset version",
    "prepare": "husky",
    "clean": "turbo run clean",
"lint": "turbo run lint",
    "lint:staged": "lint-staged --allow-empty --config lint-staged.config.cjs",
    "build:web": "pnpm --filter website build",
    "build:tokens": "chakra typegen packages/sonia-ui/src/preset/index.ts",
    "build:tokens-dev": "cross-env LOCAL=1 chakra typegen packages/sonia-ui/src/preset/index.ts",
    "build:packages": "turbo run build --filter='./packages/sonia-ui' --filter='./packages/sonia-ui-cli' --concurrency=5 --continue --env-mode=loose",
    "build:packages:force": "turbo run build --filter='./packages/sonia-ui' --filter='./packages/sonia-ui-cli' --concurrency=5 --continue --force --env-mode=loose",
    "clean:packages": "turbo run clean",
    "preinstall": "rm -rf node_modules/odiff-bin",
    "release": "pnpm run changeset:version && pnpm run build:packages"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.30.0",
    "@changesets/cli": "^2.29.7",
    "@octokit/rest": "^22.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.18.8",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "next": "^15.5.4",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "turbo": "2.5.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.26.2"
}
